{
  "name": "tree-sitter-p",
  "version": "0.1.0",
  "description": "Tree-sitter grammar for Microsoft's P language",
  "main": "bindings/node",
  "keywords": [
    "tree-sitter",
    "parser",
    "p-language"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "nan": "^2.18.0"
  },
  "devDependencies": {
    "tree-sitter-cli": "^0.25.3"
  },
  "scripts": {
    "generate": "tree-sitter generate",
    "test": "tree-sitter test",
    "build": "tree-sitter generate && node-gyp rebuild"
  },
  "tree-sitter": [
    {
      "scope": "source.p",
      "file-types": [
        "p"
      ],
      "highlights": "queries/highlights.scm"
    }
  ]
}
